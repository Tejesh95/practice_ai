```gitignore
# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables
.env
.env.*

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Type checkers
.mypy_cache/
.pytype/
.pyre/

# Linters
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# IDEs / Editors
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Generated files
output.md
```
